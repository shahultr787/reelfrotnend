# =============================================================
# Frontend .env  —  place in your React project root as ".env"
# NEVER commit this file to git
# =============================================================

# ── Backend API base URL(s) ───────────────────────────────
#
#  apiFetch.js reads this and tries each URL left-to-right
#  as a fallback chain.  List all your current backends,
#  comma-separated:
#
#  Scenario A — local backend only:
#    REACT_APP_API_BASE=http://localhost:5000
#
#  Scenario B — ngrok tunnel only:
#    REACT_APP_API_BASE=https://xxxx-xx-xx-xx-xx.ngrok-free.app
#
#  Scenario C — try ngrok first, fall back to localhost:
#    REACT_APP_API_BASE=https://xxxx-xx-xx-xx-xx.ngrok-free.app,http://localhost:5000
#
#  Scenario D — Vercel frontend + ngrok backend:
#    REACT_APP_API_BASE=https://xxxx-xx-xx-xx-xx.ngrok-free.app
#
REACT_APP_API_BASE= https://be2f-157-46-184-6.ngrok-free.app
REACT_APP_TOKEN_MODE=DEV
GENERATE_SOURCEMAP=false
CI=false

